generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================
// 서비스유형 (Service Types)
// ============================
model ServiceType {
  id        Int      @id @default(autoincrement())
  name      String   @unique // 집체, 원격교육, HRM, 스마트훈련, HR컨설팅
  nameEn    String   @map("name_en") // in_person, remote, hrm, smart_training, hr_consulting
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  customers         Customer[]
  surveys           Survey[]
  questionTemplates QuestionTemplate[]
  trainingRecords   TrainingRecord[]
  interviews        Interview[]

  @@map("service_types")
}

// ============================
// 고객사 (Customers)
// ============================
model Customer {
  id           Int      @id @default(autoincrement())
  companyName  String   @map("company_name")
  contactName  String?  @map("contact_name")
  contactTitle String?  @map("contact_title") // 과장, 대리 등
  email        String?
  phone        String?
  serviceTypeId Int     @map("service_type_id")
  salesRep     String?  @map("sales_rep") // 영업담당자
  salesTeam    String?  @map("sales_team") // 소속팀
  ecoScore     Int?     @map("eco_score") // 에코 점수
  isActive     Boolean  @default(true) @map("is_active")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  serviceType     ServiceType      @relation(fields: [serviceTypeId], references: [id])
  trainingRecords TrainingRecord[]
  distributions   Distribution[]
  responses       Response[]
  interviews      Interview[]

  @@unique([companyName, serviceTypeId])
  @@map("customers")
}

// ============================
// 설문 (Surveys)
// ============================
model Survey {
  id            Int      @id @default(autoincrement())
  title         String
  serviceTypeId Int      @map("service_type_id")
  surveyYear    Int      @map("survey_year")
  surveyMonth   Int      @map("survey_month")
  trainingMonth Int?     @map("training_month") // 교육 실시 월
  status        String   @default("draft") // draft, distributing, collecting, closed, reported
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  serviceType   ServiceType     @relation(fields: [serviceTypeId], references: [id])
  questions     SurveyQuestion[]
  distributions Distribution[]
  responses     Response[]
  interviews    Interview[]

  @@unique([serviceTypeId, surveyYear, surveyMonth])
  @@map("surveys")
}

// ============================
// 설문 문항 (Survey Questions)
// ============================
model SurveyQuestion {
  id            Int      @id @default(autoincrement())
  surveyId      Int      @map("survey_id")
  questionOrder Int      @map("question_order")
  questionText  String   @map("question_text")
  questionType  String   @map("question_type") // rating_5, rating_10, text, single_choice, multi_choice
  category      String?  // 교육내용, 강사, 운영, 전반적만족도
  optionsJson   String?  @map("options_json") // JSON array for choice options
  isRequired    Boolean  @default(true) @map("is_required")

  survey         Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responseAnswers ResponseAnswer[]

  @@map("survey_questions")
}

// ============================
// 설문 문항 템플릿 (Question Templates)
// ============================
model QuestionTemplate {
  id            Int      @id @default(autoincrement())
  serviceTypeId Int      @map("service_type_id")
  templateName  String   @map("template_name")
  questionsJson String   @map("questions_json") // JSON array of question definitions
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@map("question_templates")
}

// ============================
// 교육 실시 여부 (Training Records)
// ============================
model TrainingRecord {
  id            Int       @id @default(autoincrement())
  customerId    Int       @map("customer_id")
  trainingYear  Int       @map("training_year")
  trainingMonth Int       @map("training_month")
  serviceTypeId Int       @map("service_type_id")
  hasTraining   Boolean   @map("has_training")
  trainingName  String?   @map("training_name") // 교육과정명
  verifiedBy    String?   @map("verified_by") // 확인 담당자
  verifiedAt    DateTime? @map("verified_at")
  notes         String?

  customer    Customer    @relation(fields: [customerId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@unique([customerId, trainingYear, trainingMonth])
  @@map("training_records")
}

// ============================
// 설문 배포 (Distributions)
// ============================
model Distribution {
  id            Int       @id @default(autoincrement())
  surveyId      Int       @map("survey_id")
  customerId    Int       @map("customer_id")
  channel       String    // email, sms, both
  sentAt        DateTime? @map("sent_at")
  responseToken String    @unique @map("response_token")
  status        String    @default("pending") // pending, sent, delivered, opened, responded, bounced
  reminderCount Int       @default(0) @map("reminder_count")
  lastReminder  DateTime? @map("last_reminder")
  createdAt     DateTime  @default(now()) @map("created_at")

  survey    Survey     @relation(fields: [surveyId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
  responses Response[]

  @@unique([surveyId, customerId])
  @@map("distributions")
}

// ============================
// 설문 응답 (Responses)
// ============================
model Response {
  id             Int       @id @default(autoincrement())
  distributionId Int?      @map("distribution_id")
  surveyId       Int       @map("survey_id")
  customerId     Int       @map("customer_id")
  respondedAt    DateTime? @map("responded_at")
  isComplete     Boolean   @default(false) @map("is_complete")
  source         String    @default("web") // web, email, manual, import

  distribution Distribution? @relation(fields: [distributionId], references: [id])
  survey       Survey        @relation(fields: [surveyId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  answers      ResponseAnswer[]

  @@map("responses")
}

// ============================
// 개별 응답 (Response Answers)
// ============================
model ResponseAnswer {
  id            Int      @id @default(autoincrement())
  responseId    Int      @map("response_id")
  questionId    Int      @map("question_id")
  answerValue   String?  @map("answer_value")
  answerNumeric Float?   @map("answer_numeric")
  createdAt     DateTime @default(now()) @map("created_at")

  response Response       @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id])

  @@unique([responseId, questionId])
  @@map("response_answers")
}

// ============================
// 인터뷰 (Interviews)
// ============================
model Interview {
  id              Int       @id @default(autoincrement())
  surveyId        Int?      @map("survey_id")
  customerId      Int       @map("customer_id")
  interviewDate   DateTime? @map("interview_date")
  interviewer     String?
  interviewType   String?   @map("interview_type") // phone, visit, online
  serviceTypeId   Int       @map("service_type_id")
  satisfactionPct Int?      @map("satisfaction_pct") // 70, 90 등
  summary         String?
  vocPositive     String?   @map("voc_positive")
  vocNegative     String?   @map("voc_negative")
  audioFilePath   String?   @map("audio_file_path")
  documentPath    String?   @map("document_path")
  createdAt       DateTime  @default(now()) @map("created_at")

  survey      Survey?     @relation(fields: [surveyId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@map("interviews")
}

// ============================
// 월간 보고서 (Monthly Reports)
// ============================
model MonthlyReport {
  id          Int      @id @default(autoincrement())
  reportYear  Int      @map("report_year")
  reportMonth Int      @map("report_month")
  title       String?
  status      String   @default("draft") // draft, review, final
  overallScore Float?  @map("overall_score")
  scoresJson  String?  @map("scores_json") // JSON: per-service-type scores
  vocSummary  String?  @map("voc_summary")
  filePath    String?  @map("file_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([reportYear, reportMonth])
  @@map("monthly_reports")
}

// ============================
// 데이터 가져오기 이력 (Import Logs)
// ============================
model ImportLog {
  id             Int      @id @default(autoincrement())
  fileName       String   @map("file_name")
  filePath       String?  @map("file_path")
  importType     String   @map("import_type") // customers, responses, training, interviews
  recordsTotal   Int      @default(0) @map("records_total")
  recordsSuccess Int      @default(0) @map("records_success")
  recordsFailed  Int      @default(0) @map("records_failed")
  errorsJson     String?  @map("errors_json")
  importedAt     DateTime @default(now()) @map("imported_at")

  @@map("import_logs")
}
