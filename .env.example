# .env.local 에 복사해 값을 채운다.
# 운영 Vercel 프로젝트 변수는 `vercel env pull .env.local --environment=preview --yes` 로 동기화 가능
# (AGENTS.md "로컬 개발 환경 세팅" 섹션 참조).
#
# ──────────────────────────────────────────────────────────────────────
# Supabase (필수)
# ──────────────────────────────────────────────────────────────────────

# 프로젝트 URL — https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — 클라이언트·서버 공통. RLS 뒤에서만 노출
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — 서버 전용 (createAdminClient 경로). RLS bypass. 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────
# 앱 URL (필수 — 이메일·SMS 본문의 토큰 URL 생성)
# ──────────────────────────────────────────────────────────────────────

# 로컬: http://localhost:3000 · 프로덕션: https://exc-survey.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────
# Prisma (레거시, 이관 완료 전까지 유지 — Customer/TrainingRecord/Interview)
# ──────────────────────────────────────────────────────────────────────

# Supabase Transaction Pooler (port 6543, 런타임)
# `prisma db pull` 시에는 Session Pooler (5432) 로 바꿔서 실행 (AGENTS.md 참조)
DATABASE_URL=

# 로컬 타입 생성용 (프로덕션 런타임 무관). https://supabase.com/dashboard/account/tokens
# 미설정이면 `npm run types:gen` 이 스킵됨
SUPABASE_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Vercel Cron 보호 (필수 — /api/cron/* Bearer 검증)
# ──────────────────────────────────────────────────────────────────────

# Vercel Development 환경에 자동 주입. Preview/Production 에서는 별도 secret
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────
# CS Bridge (외부 CS 플랫폼 연동 — 선택)
# ──────────────────────────────────────────────────────────────────────

# /api/distributions/cs-bridge 의 x-api-key 헤더 검증
CS_BRIDGE_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# 이메일 발송 — HIWORKS 공식 API (우선 경로)
# ──────────────────────────────────────────────────────────────────────

HIWORKS_OFFICE_TOKEN=
HIWORKS_USER_ID=

# ──────────────────────────────────────────────────────────────────────
# 이메일 발송 — SMTP fallback (Office365 등)
# ──────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 발신자 주소를 SMTP_USER 와 다르게 쓰고 싶을 때만
SMTP_FROM=

# ──────────────────────────────────────────────────────────────────────
# SMS 발송 — PPURIO (우선)
# ──────────────────────────────────────────────────────────────────────

PPURIO_USERNAME=
PPURIO_TOKEN=
PPURIO_SENDER_PHONE=

# ──────────────────────────────────────────────────────────────────────
# SMS 발송 — ALIGO (레거시/fallback)
# ──────────────────────────────────────────────────────────────────────

ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_PHONE=

# ──────────────────────────────────────────────────────────────────────
# E2E 테스트 (로컬 개발용 — 선택)
# ──────────────────────────────────────────────────────────────────────

# 테스트 baseURL — 비우면 프로덕션 URL 사용
E2E_BASE_URL=http://localhost:3000

# 응답자 flow 테스트용 공개 토큰
E2E_SURVEY_TOKEN=

# 관리자 UI 테스트용 계정 (있으면 자동 skip 해제)
SURVEY_CS_ID=
SURVEY_CS_PW=
# Legacy 변수명 (SURVEY_CS_* 가 없을 때 fallback)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
