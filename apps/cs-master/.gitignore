# 비밀/자격증명 — 절대 커밋 금지
secrets/
.env
*.env
!.env.example

# 의존성/빌드 산출물
node_modules/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 런타임/로그
logs/
downloads/
*.log

# 개인정보 포함 작업 파일 (학습자 이름/연락처)
# 명시적으로 add 하지 않는 한 커밋 차단
*.xlsx
*.docx
*.csv
!lib/**/test/fixtures/**/*.csv

# 개발 산출물
test_output.*
response_r*.json
.playwright-mcp/

# 에디터/도구 로컬 설정
.claude/
.vscode/
.idea/

# Docker 로컬 임시
*.tar
*.tar.gz
