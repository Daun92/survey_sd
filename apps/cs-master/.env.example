# ==================== 필수 ====================
# API 인증 키 (클라이언트가 X-API-Key 헤더로 전송)
BRIS_API_KEY=change-me-to-random-string

# ==================== BRIS 인증 (택 1) ====================
# 방법 A: 사용자 자격증명
BRIS_USER_ID=
BRIS_PASSWORD=

# 방법 B: 쿠키 파일 (./secrets/bris_cookies.json)
# 컨테이너 내부 경로로 지정
BRIS_COOKIE_FILE=/secrets/bris_cookies.json

# ==================== Supabase (sync 엔드포인트 사용 시) ====================
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ==================== 선택 ====================
# 호스트 바인딩 포트 (컨테이너 내부는 항상 8000)
HOST_PORT=8000

# uvicorn 워커 수
UVICORN_WORKERS=2
